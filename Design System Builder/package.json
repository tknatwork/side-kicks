{
  "name": "design-system-builder",
  "version": "0.1.0",
  "private": true,
  "description": "AI-driven design system builder for Figma — Claude-required toolkit for creating 3-tier variable architectures",
  "author": "Tushar Kant Naik",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "packages/core",
    "packages/figma-api",
    "packages/builder-plugin",
    "packages/mcp-server",
    "packages/orchestration-server",
    "packages/licensing",
    "packages/guardrails",
    "packages/updater"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:plugin": "turbo run build --filter=@dsb/builder-plugin",
    "build:servers": "turbo run build --filter=@dsb/mcp-server --filter=@dsb/orchestration-server",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "server:start": "node packages/orchestration-server/dist/index.js"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "prettier": "^3.4.0",
    "eslint": "^9.15.0"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.18",
      "@hono/node-server": ">=1.19.10",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "path-to-regexp@>=1.0.0 <8.4.0": ">=8.4.0",
      "fast-uri": ">=3.1.1",
      "esbuild@<0.25.0": ">=0.25.0",
      "esbuild@>=0.25.0 <0.27.0": ">=0.27.0",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "vite@<6.4.2": ">=6.4.2",
      "postcss": ">=8.5.10",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "ip-address": ">=10.1.1",
      "flatted": ">=3.4.2",
      "express-rate-limit": ">=8.2.2",
      "qs": ">=6.15.2",
      "ajv@<6.14.0": ">=6.14.0",
      "brace-expansion@<1.1.13": ">=1.1.13"
    }
  }
}
