{
  "name": "@dsb/builder-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Main Figma plugin — headless command executor with 59 command handlers and minimal status UI",
  "main": "code.js",
  "scripts": {
    "build": "tsc && node scripts/bundle.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist code.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dsb/core": "workspace:*",
    "@dsb/figma-api": "workspace:*"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "typescript": "^5.6.0",
    "esbuild": "^0.25.0",
    "vitest": "^4.1.0"
  }
}
