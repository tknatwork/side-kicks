{
  "name": "@dsb/orchestration-server",
  "version": "0.1.0",
  "private": true,
  "description": "HTTP + WebSocket command bridge between MCP server and Figma plugin",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dsb/core": "workspace:*",
    "@dsb/guardrails": "workspace:*",
    "ws": "^8.18.0",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
