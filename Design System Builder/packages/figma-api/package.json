{
  "name": "@dsb/figma-api",
  "version": "0.1.0",
  "private": true,
  "description": "Thin async-safe wrappers around Figma Plugin API — variables, styles, pages, nodes, components, fonts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dsb/core": "workspace:*",
    "@dsb/guardrails": "workspace:*"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
