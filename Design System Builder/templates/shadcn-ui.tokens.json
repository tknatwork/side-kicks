{
  "$schema": "./schema/template.schema.json",
  "name": "shadcn/ui",
  "version": "1.0.0",
  "description": "shadcn/ui + Base UI + Tailwind CSS token template. HSL-native color system with CSS variable semantics. Maps Tailwind's utility-first approach to a 3-tier Figma variable architecture.",
  "framework": "react",
  "tiers": {
    "primitives": {
      "collectionName": "Primitives",
      "modes": ["Value"],
      "description": "Raw design values — color palette, spacing scale, typography, radius, shadows"
    },
    "semantic": {
      "collectionName": "Semantic",
      "modes": ["Value"],
      "description": "Purpose-driven aliases — background, foreground, border, ring, muted, accent, destructive"
    },
    "component": {
      "collectionName": "Mapped",
      "modes": ["Light", "Dark"],
      "description": "Theme-resolved tokens — light/dark mode mappings for all semantic tokens"
    },
    "breakpoints": {
      "collectionName": "Breakpoints",
      "modes": ["Desktop", "Tablet", "Mobile"],
      "description": "Responsive tokens — typography sizes, spacing, and layout values per breakpoint"
    }
  },
  "tokens": {
    "primitives": {
      "color": {
        "_description": "Tailwind-compatible color palette with 11 steps (50-950)",
        "zinc": {
          "50":  { "type": "color", "value": "#fafafa" },
          "100": { "type": "color", "value": "#f4f4f5" },
          "200": { "type": "color", "value": "#e4e4e7" },
          "300": { "type": "color", "value": "#d4d4d8" },
          "400": { "type": "color", "value": "#a1a1aa" },
          "500": { "type": "color", "value": "#71717a" },
          "600": { "type": "color", "value": "#52525b" },
          "700": { "type": "color", "value": "#3f3f46" },
          "800": { "type": "color", "value": "#27272a" },
          "900": { "type": "color", "value": "#18181b" },
          "950": { "type": "color", "value": "#09090b" }
        },
        "slate": {
          "50":  { "type": "color", "value": "#f8fafc" },
          "100": { "type": "color", "value": "#f1f5f9" },
          "200": { "type": "color", "value": "#e2e8f0" },
          "300": { "type": "color", "value": "#cbd5e1" },
          "400": { "type": "color", "value": "#94a3b8" },
          "500": { "type": "color", "value": "#64748b" },
          "600": { "type": "color", "value": "#475569" },
          "700": { "type": "color", "value": "#334155" },
          "800": { "type": "color", "value": "#1e293b" },
          "900": { "type": "color", "value": "#0f172a" },
          "950": { "type": "color", "value": "#020617" }
        },
        "blue": {
          "50":  { "type": "color", "value": "#eff6ff" },
          "100": { "type": "color", "value": "#dbeafe" },
          "200": { "type": "color", "value": "#bfdbfe" },
          "300": { "type": "color", "value": "#93c5fd" },
          "400": { "type": "color", "value": "#60a5fa" },
          "500": { "type": "color", "value": "#3b82f6" },
          "600": { "type": "color", "value": "#2563eb" },
          "700": { "type": "color", "value": "#1d4ed8" },
          "800": { "type": "color", "value": "#1e40af" },
          "900": { "type": "color", "value": "#1e3a8a" },
          "950": { "type": "color", "value": "#172554" }
        },
        "red": {
          "50":  { "type": "color", "value": "#fef2f2" },
          "100": { "type": "color", "value": "#fee2e2" },
          "200": { "type": "color", "value": "#fecaca" },
          "300": { "type": "color", "value": "#fca5a5" },
          "400": { "type": "color", "value": "#f87171" },
          "500": { "type": "color", "value": "#ef4444" },
          "600": { "type": "color", "value": "#dc2626" },
          "700": { "type": "color", "value": "#b91c1c" },
          "800": { "type": "color", "value": "#991b1b" },
          "900": { "type": "color", "value": "#7f1d1d" },
          "950": { "type": "color", "value": "#450a0a" }
        },
        "green": {
          "50":  { "type": "color", "value": "#f0fdf4" },
          "100": { "type": "color", "value": "#dcfce7" },
          "200": { "type": "color", "value": "#bbf7d0" },
          "300": { "type": "color", "value": "#86efac" },
          "400": { "type": "color", "value": "#4ade80" },
          "500": { "type": "color", "value": "#22c55e" },
          "600": { "type": "color", "value": "#16a34a" },
          "700": { "type": "color", "value": "#15803d" },
          "800": { "type": "color", "value": "#166534" },
          "900": { "type": "color", "value": "#14532d" },
          "950": { "type": "color", "value": "#052e16" }
        },
        "yellow": {
          "50":  { "type": "color", "value": "#fefce8" },
          "100": { "type": "color", "value": "#fef9c3" },
          "200": { "type": "color", "value": "#fef08a" },
          "300": { "type": "color", "value": "#fde047" },
          "400": { "type": "color", "value": "#facc15" },
          "500": { "type": "color", "value": "#eab308" },
          "600": { "type": "color", "value": "#ca8a04" },
          "700": { "type": "color", "value": "#a16207" },
          "800": { "type": "color", "value": "#854d0e" },
          "900": { "type": "color", "value": "#713f12" },
          "950": { "type": "color", "value": "#422006" }
        },
        "white": { "type": "color", "value": "#ffffff" },
        "black": { "type": "color", "value": "#000000" }
      },
      "spacing": {
        "_description": "Tailwind-compatible spacing scale (base: 4px)",
        "0":   { "type": "float", "value": 0 },
        "0.5": { "type": "float", "value": 2 },
        "1":   { "type": "float", "value": 4 },
        "1.5": { "type": "float", "value": 6 },
        "2":   { "type": "float", "value": 8 },
        "2.5": { "type": "float", "value": 10 },
        "3":   { "type": "float", "value": 12 },
        "3.5": { "type": "float", "value": 14 },
        "4":   { "type": "float", "value": 16 },
        "5":   { "type": "float", "value": 20 },
        "6":   { "type": "float", "value": 24 },
        "7":   { "type": "float", "value": 28 },
        "8":   { "type": "float", "value": 32 },
        "9":   { "type": "float", "value": 36 },
        "10":  { "type": "float", "value": 40 },
        "12":  { "type": "float", "value": 48 },
        "14":  { "type": "float", "value": 56 },
        "16":  { "type": "float", "value": 64 },
        "20":  { "type": "float", "value": 80 },
        "24":  { "type": "float", "value": 96 }
      },
      "radius": {
        "_description": "shadcn/ui border radius scale",
        "none": { "type": "float", "value": 0 },
        "sm":   { "type": "float", "value": 4 },
        "md":   { "type": "float", "value": 6 },
        "lg":   { "type": "float", "value": 8 },
        "xl":   { "type": "float", "value": 12 },
        "2xl":  { "type": "float", "value": 16 },
        "full": { "type": "float", "value": 9999 }
      },
      "font-size": {
        "_description": "Tailwind type scale",
        "xs":   { "type": "float", "value": 12 },
        "sm":   { "type": "float", "value": 14 },
        "base": { "type": "float", "value": 16 },
        "lg":   { "type": "float", "value": 18 },
        "xl":   { "type": "float", "value": 20 },
        "2xl":  { "type": "float", "value": 24 },
        "3xl":  { "type": "float", "value": 30 },
        "4xl":  { "type": "float", "value": 36 },
        "5xl":  { "type": "float", "value": 48 }
      },
      "line-height": {
        "tight":  { "type": "float", "value": 1.25 },
        "snug":   { "type": "float", "value": 1.375 },
        "normal": { "type": "float", "value": 1.5 },
        "relaxed":{ "type": "float", "value": 1.625 },
        "loose":  { "type": "float", "value": 2 }
      },
      "font-family": {
        "sans":  { "type": "string", "value": "Inter" },
        "mono":  { "type": "string", "value": "Geist Mono" }
      },
      "shadow": {
        "_description": "Elevation values (blur radius in px)",
        "sm":  { "type": "float", "value": 2 },
        "md":  { "type": "float", "value": 6 },
        "lg":  { "type": "float", "value": 15 },
        "xl":  { "type": "float", "value": 25 }
      }
    },
    "semantic": {
      "_description": "CSS variable semantics matching shadcn/ui's --background, --foreground, etc.",
      "bg": {
        "background":      { "type": "color", "alias": "color/white" },
        "card":            { "type": "color", "alias": "color/white" },
        "popover":         { "type": "color", "alias": "color/white" },
        "primary":         { "type": "color", "alias": "color/zinc/900" },
        "secondary":       { "type": "color", "alias": "color/zinc/100" },
        "muted":           { "type": "color", "alias": "color/zinc/100" },
        "accent":          { "type": "color", "alias": "color/zinc/100" },
        "destructive":     { "type": "color", "alias": "color/red/500" },
        "input":           { "type": "color", "alias": "color/zinc/200" },
        "ring":            { "type": "color", "alias": "color/zinc/950" }
      },
      "fg": {
        "foreground":      { "type": "color", "alias": "color/zinc/950" },
        "card-foreground": { "type": "color", "alias": "color/zinc/950" },
        "popover-foreground": { "type": "color", "alias": "color/zinc/950" },
        "primary-foreground":  { "type": "color", "alias": "color/zinc/50" },
        "secondary-foreground": { "type": "color", "alias": "color/zinc/900" },
        "muted-foreground":    { "type": "color", "alias": "color/zinc/500" },
        "accent-foreground":   { "type": "color", "alias": "color/zinc/900" },
        "destructive-foreground": { "type": "color", "alias": "color/white" }
      },
      "border": {
        "default": { "type": "color", "alias": "color/zinc/200" },
        "input":   { "type": "color", "alias": "color/zinc/200" }
      },
      "chart": {
        "1": { "type": "color", "alias": "color/blue/500" },
        "2": { "type": "color", "alias": "color/green/500" },
        "3": { "type": "color", "alias": "color/yellow/500" },
        "4": { "type": "color", "alias": "color/red/500" },
        "5": { "type": "color", "alias": "color/zinc/500" }
      },
      "spacing": {
        "page-padding":    { "type": "float", "alias": "spacing/6" },
        "section-gap":     { "type": "float", "alias": "spacing/8" },
        "card-padding":    { "type": "float", "alias": "spacing/6" },
        "input-padding-x": { "type": "float", "alias": "spacing/3" },
        "input-padding-y": { "type": "float", "alias": "spacing/2" },
        "button-padding-x":{ "type": "float", "alias": "spacing/4" },
        "button-padding-y":{ "type": "float", "alias": "spacing/2" },
        "gap-sm":          { "type": "float", "alias": "spacing/2" },
        "gap-md":          { "type": "float", "alias": "spacing/4" },
        "gap-lg":          { "type": "float", "alias": "spacing/6" }
      },
      "radius": {
        "button": { "type": "float", "alias": "radius/md" },
        "card":   { "type": "float", "alias": "radius/lg" },
        "input":  { "type": "float", "alias": "radius/md" },
        "badge":  { "type": "float", "alias": "radius/full" }
      },
      "font-size": {
        "heading-1": { "type": "float", "alias": "font-size/4xl" },
        "heading-2": { "type": "float", "alias": "font-size/3xl" },
        "heading-3": { "type": "float", "alias": "font-size/2xl" },
        "heading-4": { "type": "float", "alias": "font-size/xl" },
        "body":      { "type": "float", "alias": "font-size/base" },
        "body-sm":   { "type": "float", "alias": "font-size/sm" },
        "caption":   { "type": "float", "alias": "font-size/xs" },
        "code":      { "type": "float", "alias": "font-size/sm" }
      }
    },
    "component": {
      "_description": "Theme modes: Light and Dark. shadcn/ui's theming pattern.",
      "Light": {
        "bg/background":      { "alias": "color/white" },
        "bg/card":            { "alias": "color/white" },
        "bg/primary":         { "alias": "color/zinc/900" },
        "bg/secondary":       { "alias": "color/zinc/100" },
        "bg/muted":           { "alias": "color/zinc/100" },
        "bg/accent":          { "alias": "color/zinc/100" },
        "bg/destructive":     { "alias": "color/red/500" },
        "fg/foreground":      { "alias": "color/zinc/950" },
        "fg/primary-foreground": { "alias": "color/zinc/50" },
        "fg/muted-foreground":   { "alias": "color/zinc/500" },
        "fg/destructive-foreground": { "alias": "color/white" },
        "border/default":     { "alias": "color/zinc/200" },
        "bg/ring":            { "alias": "color/zinc/950" }
      },
      "Dark": {
        "bg/background":      { "alias": "color/zinc/950" },
        "bg/card":            { "alias": "color/zinc/950" },
        "bg/primary":         { "alias": "color/zinc/50" },
        "bg/secondary":       { "alias": "color/zinc/800" },
        "bg/muted":           { "alias": "color/zinc/800" },
        "bg/accent":          { "alias": "color/zinc/800" },
        "bg/destructive":     { "alias": "color/red/900" },
        "fg/foreground":      { "alias": "color/zinc/50" },
        "fg/primary-foreground": { "alias": "color/zinc/900" },
        "fg/muted-foreground":   { "alias": "color/zinc/400" },
        "fg/destructive-foreground": { "alias": "color/zinc/50" },
        "border/default":     { "alias": "color/zinc/800" },
        "bg/ring":            { "alias": "color/zinc/300" }
      }
    }
  },
  "fonts": [
    {
      "family": "Inter",
      "weights": ["Regular", "Medium", "Semibold", "Bold"],
      "fallback": "system-ui, -apple-system, sans-serif"
    },
    {
      "family": "Geist Mono",
      "weights": ["Regular", "Medium"],
      "fallback": "ui-monospace, monospace"
    }
  ]
}
