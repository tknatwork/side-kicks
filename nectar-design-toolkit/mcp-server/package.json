{
  "name": "figma-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Figma design system integration - Portfolio project",
  "type": "module",
  "bin": {
    "figma-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "dev": "tsc --watch"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^16.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "hono": ">=4.12.18",
    "@hono/node-server": ">=1.19.10",
    "path-to-regexp": ">=8.4.0",
    "fast-uri": ">=3.1.2",
    "ws": ">=8.20.1",
    "qs": ">=6.15.2",
    "ajv": ">=6.14.0",
    "minimatch": ">=3.1.4",
    "brace-expansion": ">=1.1.13"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "figma",
    "design-tokens",
    "design-system"
  ],
  "author": "Portfolio Project",
  "license": "MIT"
}
